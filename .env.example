# Public values used by the browser. These are safe to expose.
# VITE_SUPABASE_ANON_KEY accepts the new sb_publishable_... key or the
# legacy anon public key. Never use a secret/service-role key here.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_PUBLISHABLE_KEY"

# The public Vercel URL or custom domain.
VITE_APP_URL="https://YOUR_PROJECT.vercel.app"

# LINE Login is handled by a Supabase Edge Function.
# Store LINE_CHANNEL_ID and LINE_CHANNEL_SECRET in Supabase secrets,
# never in a VITE_ variable or GitHub repository.
VITE_LINE_LOGIN_URL="https://YOUR_PROJECT.supabase.co/functions/v1/line-login"
