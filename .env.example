# Public values used by the browser. These are safe to expose.
VITE_SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# The public GitHub Pages URL, including the repository path.
VITE_APP_URL="https://YOUR_GITHUB_NAME.github.io/YOUR_REPOSITORY"

# LINE Login is handled by a Supabase Edge Function.
# Store LINE_CHANNEL_ID and LINE_CHANNEL_SECRET in Supabase secrets,
# never in a VITE_ variable or GitHub repository.
VITE_LINE_LOGIN_URL="https://YOUR_PROJECT.supabase.co/functions/v1/line-login"
